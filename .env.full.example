# Enterprise KB Full Stack Environment
# Copy to .env.full and edit before running scripts/full-init.sh

# ===== Host / domains =====
KB_BASE_DOMAIN=kb.local
PAPERLESS_HOST=paperless.kb.local
RAGFLOW_HOST=ragflow.kb.local
DIFY_HOST=dify.kb.local
BRIDGE_HOST=bridge.kb.local
ENABLE_CADDY_INTERNAL_TLS=false

# ===== Paths =====
KB_ROOT=./runtime
PAPERLESS_DATA=./runtime/paperless
RAGFLOW_DIR=./runtime/vendor/ragflow
DIFY_DIR=./runtime/vendor/dify
BACKUP_DIR=./runtime/backups

# ===== Paperless admin =====
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me-paperless
PAPERLESS_ADMIN_MAIL=admin@example.local
PAPERLESS_SECRET_KEY=replace-with-random-secret
PAPERLESS_TIME_ZONE=Asia/Shanghai
PAPERLESS_URL=http://paperless.kb.local:8080
PAPERLESS_OCR_LANGUAGE=chi_sim+eng
PAPERLESS_OCR_LANGUAGES=chi-sim eng
PAPERLESS_CONSUMER_RECURSIVE=true
PAPERLESS_CONSUMER_SUBDIRS_AS_TAGS=true
PAPERLESS_FILENAME_FORMAT={{ created_year }}/{{ correspondent }}/{{ document_type }}/{{ title }}

# ===== Shared database secrets =====
PAPERLESS_POSTGRES_PASSWORD=change-me-paperless-db

# ===== Bridge sync =====
BRIDGE_API_KEY=change-me-bridge-key
BRIDGE_SYNC_ENABLED=true
BRIDGE_REQUIRE_TAG=状态/可入RAG
BRIDGE_SUCCESS_TAG=状态/已入RAG
BRIDGE_FAILED_TAG=状态/同步失败
BRIDGE_POLL_SECONDS=120

# RAGFlow API settings - fill these after RAGFlow admin/API key is created.
# If RAGFlow runs from its official compose on the host, use http://host.docker.internal:<port> from kb-bridge.
RAGFLOW_BASE_URL=http://host.docker.internal:80
RAGFLOW_API_KEY=
RAGFLOW_CONTRACT_DATASET_ID=
RAGFLOW_BID_DATASET_ID=
RAGFLOW_PROPOSAL_DATASET_ID=
RAGFLOW_DELIVERY_DATASET_ID=
RAGFLOW_GENERAL_DATASET_ID=

# ===== Model gateway placeholders =====
# Optional: NewAPI / Doubao / OpenAI-compatible gateway for RAGFlow and Dify.
LLM_BASE_URL=
LLM_API_KEY=
CHAT_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=2048

# ===== Dify / RAGFlow versions =====
DIFY_GIT_REF=main
RAGFLOW_GIT_REF=main

# ===== Ports exposed on host =====
# Keep Caddy on 8080/8443 by default so official RAGFlow/Dify compose stacks do not fight it for port 80/443.
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
PAPERLESS_DIRECT_PORT=18000
BRIDGE_DIRECT_PORT=18080
RAGFLOW_HTTP_PORT=80
DIFY_HTTP_PORT=8088
